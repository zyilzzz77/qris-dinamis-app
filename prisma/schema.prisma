// bikinqrisdinamis — Prisma Schema (Prisma 7 + SQLite)
// Prisma 7: use "prisma-client" provider (not "prisma-client-js")
// The datasource block is still required for schema validation

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qrisStatics  QrisStatic[]
  transactions Transaction[]
  apiRequestLogs ApiRequestLog[]
}

model QrisStatic {
  id           String   @id @default(cuid())
  userId       String
  rawString    String
  merchantName String
  merchantCity String
  nmid         String
  imageUrl     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id            String    @id @default(cuid())
  userId        String
  qrisStaticId  String
  description   String?
  baseAmount    Float
  taxType       String    @default("NONE")
  taxRate       Float     @default(0)
  taxAmount     Float     @default(0)
  totalAmount   Float
  qrisString    String
  qrisImageUrl  String?
  status        String    @default("PENDING")
  proofImageUrl String?
  confirmedAt   DateTime?
  confirmedBy   String?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrisStatic QrisStatic @relation(fields: [qrisStaticId], references: [id], onDelete: Cascade)
}

model ApiRequestLog {
  id         String   @id @default(cuid())
  userId     String?
  endpoint   String
  method     String
  statusCode Int?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([endpoint, createdAt])
}
