# bikinqrisdinamis - Example Environment
# Copy this file to .env.local for local dev, or set these vars in production.

# Production domain
NEXT_PUBLIC_SITE_URL="https://bikinqris.app"
NEXTAUTH_URL="https://bikinqris.app"

# For local development (uncomment and adjust)
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# NEXTAUTH_URL="http://localhost:3000"

# Prisma / database
DATABASE_URL="file:./dev.db"

# WAJIB sama nilainya (Auth.js v5)
AUTH_SECRET="GANTI_DENGAN_SECRET_RANDOM_PANJANG_MIN_32_CHAR"
NEXTAUTH_SECRET="GANTI_DENGAN_SECRET_RANDOM_PANJANG_MIN_32_CHAR"

# Opsional
GOOGLE_SITE_VERIFICATION=""

# Email verification secret (pisah dari auth secret lebih aman)
EMAIL_VERIFICATION_SECRET="GANTI_DENGAN_SECRET_RANDOM_PANJANG_MIN_32_CHAR"

# OTP policy (opsional, default dipakai jika kosong)
EMAIL_VERIFICATION_EXPIRES_MINUTES="10"
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS="60"
EMAIL_VERIFICATION_MAX_ATTEMPTS="5"

# Forgot password token policy
PASSWORD_RESET_SECRET="GANTI_DENGAN_SECRET_RANDOM_PANJANG_MIN_32_CHAR"
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES="10"

# SMTP (wajib untuk kirim kode verifikasi email)
SMTP_HOST="mail.domainkamu.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="no-reply@domainkamu.com"
SMTP_PASS="PASSWORD_SMTP"
SMTP_FROM="no-reply@domainkamu.com"
SMTP_FROM_NAME="bikinqrisdinamis"

# Sender per fungsi email (opsional, fallback ke SMTP_FROM)
# OTP verifikasi akun
SMTP_FROM_ALERT="alert@bikinqrisdinamis.app"
SMTP_FROM_ALERT_NAME="bikinqrisdinamis Alert"
SMTP_USER_ALERT="alert@bikinqrisdinamis.app"
SMTP_PASS_ALERT="PASSWORD_SMTP_ALERT"

# Notifikasi user: akun berhasil dibuat, lupa password, maintenance, dll
SMTP_FROM_NOTIFICATION="notification@bikinqrisdinamis.app"
SMTP_FROM_NOTIFICATION_NAME="bikinqrisdinamis Notification"
SMTP_USER_NOTIFICATION="notification@bikinqrisdinamis.app"
SMTP_PASS_NOTIFICATION="PASSWORD_SMTP_NOTIFICATION"

# Customer service: kendala aplikasi, tiket bantuan, dll
SMTP_FROM_CUSTOMER_SERVICE="customer-services@bikinqrisdinamis.app"
SMTP_FROM_CUSTOMER_SERVICE_NAME="bikinqrisdinamis Customer Services"
SMTP_USER_CUSTOMER_SERVICE="customer-services@bikinqrisdinamis.app"
SMTP_PASS_CUSTOMER_SERVICE="PASSWORD_SMTP_CUSTOMER_SERVICE"

# Inbox tujuan support ticket (opsional, default pakai SMTP_FROM_CUSTOMER_SERVICE)
CUSTOMER_SERVICE_INBOX_EMAIL="customer-services@bikinqrisdinamis.app"

# Email owner untuk copy otomatis laporan support
SUPPORT_OWNER_EMAIL="enzilaja@gmail.com"
